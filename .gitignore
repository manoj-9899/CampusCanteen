# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# database
/prisma/*.db
/prisma/*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# LaTeX build artifacts (report source lives in docs/batu-project-report/)
docs/batu-project-report/*.aux
docs/batu-project-report/*.log
docs/batu-project-report/*.lof
docs/batu-project-report/*.lot
docs/batu-project-report/*.out
docs/batu-project-report/*.toc
docs/batu-project-report/*.pdf
docs/batu-project-report/*.fls
docs/batu-project-report/*.fdb_latexmk
docs/batu-project-report/*.synctex.gz
