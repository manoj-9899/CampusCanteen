# Copy to .env and adjust.
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Mac/Linux)

# --- Local demo (Docker Postgres) ---
# 1. docker compose up -d
# 2. Use this URL:
DATABASE_URL="postgresql://canteen:canteen@localhost:5432/canteen"

# --- OR local/cloud via Neon (no Docker) ---
# Create a free project at https://neon.tech and paste the connection string:
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth — use a long random string in production (Vercel env vars)
JWT_SECRET="change-me-to-a-long-random-secret"
