# Copy to .env and adjust.
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Mac/Linux)

# -----------------------------------------------------------------------------
# Local development — SQLite (no server install needed)
# -----------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# Auth — use a long random string in production (Netlify env var only)
JWT_SECRET="change-me-to-a-long-random-secret"

# -----------------------------------------------------------------------------
# Production (Neon + Netlify) — set in Netlify dashboard, NOT in this file
# -----------------------------------------------------------------------------
# DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"
# JWT_SECRET="<generate with: openssl rand -base64 32>"
# NODE_VERSION=20   (optional — already in netlify.toml)

# Do NOT set TEST_PAYMENT_MODE in production (ignored when NODE_ENV=production).

# -----------------------------------------------------------------------------
# Development / test only — payment simulation (see docs/PAYMENT_FLOW.md)
# -----------------------------------------------------------------------------
# TEST_PAYMENT_MODE=success        # default
# TEST_PAYMENT_MODE=failure        # decline, order stays pending
# TEST_PAYMENT_MODE=timeout        # 408, no DB change
# TEST_PAYMENT_MODE=stock_changed    # 409 inventory race
